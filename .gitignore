# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin
.env.local

# stray screenshots dropped at the repo root (macOS paste/screencapture),
# not intentional project assets — real images live under public/
/image.png
/image copy*.png
/screencapture-*.png

# design-sync: staged converter scripts, build output, and machine state.
# config.json, NOTES.md, conventions.md, previews/, overrides/ ARE committed.
/.ds-sync/
/ds-bundle/
/.design-sync/.cache/
/.design-sync/learnings/
/.design-sync/node_modules
/.design-sync/fonts/
